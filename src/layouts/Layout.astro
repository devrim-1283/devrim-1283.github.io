---
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'tr' | 'en';
  canonical?: string;
  type?: 'website' | 'article';
  publishedAt?: string;
  tags?: string[];
}

const {
  title,
  description = 'Done Dynamics — kurumsal yazılım şirketi mühendislik notları.',
  lang = 'tr',
  canonical,
  type = 'website',
  publishedAt,
  tags = [],
} = Astro.props;

const site = 'https://devrim-1283.github.io';
const url = canonical ?? site + Astro.url.pathname;
const mainSite = 'https://donedynamics.com';
const mainUrl = lang === 'en' ? `${mainSite}/en` : mainSite;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:site_name" content="Done Dynamics Engineering" />
    <meta name="twitter:card" content="summary_large_image" />
    {publishedAt && <meta property="article:published_time" content={publishedAt} />}
    {tags.map((t) => <meta property="article:tag" content={t} />)}
    <link rel="alternate" type="application/rss+xml" title="Done Dynamics Engineering" href="/rss.xml" />
  </head>
  <body>
    <header class="border-b border-ink-200 bg-white">
      <div class="container-page flex items-center justify-between py-5">
        <a href={lang === 'en' ? '/en/' : '/'} class="font-semibold tracking-tight text-ink-900">
          Done Dynamics <span class="text-ink-400">/ eng</span>
        </a>
        <nav class="flex items-center gap-5 text-sm">
          <a href={lang === 'en' ? '/en/' : '/'} class="text-ink-600 hover:text-ink-900">{lang === 'en' ? 'Posts' : 'Yazılar'}</a>
          <a href={mainUrl} class="text-accent hover:underline">donedynamics.com →</a>
          <a href={lang === 'en' ? '/' : '/en/'} class="text-ink-400 hover:text-ink-900">{lang === 'en' ? 'TR' : 'EN'}</a>
        </nav>
      </div>
    </header>
    <main class="container-page py-12 sm:py-16">
      <slot />
    </main>

    <section aria-label={lang === 'en' ? 'About Done Dynamics' : 'Done Dynamics hakkında'} class="border-t border-ink-200 bg-white">
      <div class="container-page py-14 sm:py-16">
        <p class="text-xs font-semibold uppercase tracking-wider text-ink-400">
          {lang === 'en' ? 'About the engineering team' : 'Mühendislik ekibi hakkında'}
        </p>
        <h2 class="mt-3 text-2xl sm:text-3xl font-semibold tracking-tight text-ink-900">
          {lang === 'en'
            ? 'Done Dynamics — enterprise software engineering, delivered end to end.'
            : 'Done Dynamics — uçtan uca teslim edilen kurumsal yazılım mühendisliği.'}
        </h2>
        {lang === 'en' ? (
          <div class="mt-5 space-y-4 text-sm sm:text-base leading-relaxed text-ink-700">
            <p>
              The notes published here are written by the engineering team at
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com/en"> Done Dynamics</a>,
              an Alanya TEKMER-based enterprise software company serving customers across Türkiye, the EU and MENA.
              Our delivery practice covers
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com/en/solutions/web-development"> enterprise web application development</a>,
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com/en/solutions/mobile-development"> iOS and Android mobile app development</a>,
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com/en/solutions/custom-applications"> custom business applications</a>
              and
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com/en/solutions/backup-storage"> KVKK / GDPR-compliant backup and S3-compatible storage</a>.
            </p>
            <p>
              Mobile is a first-class delivery line — not an afterthought. We design Flutter and native iOS / Android applications with
              offline resilience, push notifications, App Store and Google Play release management,
              and continuous monitoring as part of the contract. The same engineering team that ships the web
              tier also owns the mobile build and release pipeline.
            </p>
            <p>
              Read more about our company on the
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com/en/company"> Done Dynamics corporate page</a>,
              browse the
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com/en/product/nextcloud"> self-hosted Nextcloud workspace offering</a>,
              or
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com/en/contact"> request a scoping call</a>.
            </p>
          </div>
        ) : (
          <div class="mt-5 space-y-4 text-sm sm:text-base leading-relaxed text-ink-700">
            <p>
              Burada yayımlanan teknik notlar,
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com"> Done Dynamics</a>
              mühendislik ekibi tarafından yazılır. Done Dynamics, Alanya TEKMER bünyesinde kurulmuş bir
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com/company"> kurumsal yazılım şirketi</a>
              olarak Türkiye genelinde
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com/solutions/web-development"> kurumsal web sitesi ve B2B portal geliştirme</a>,
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com/solutions/mobile-development"> iOS ve Android mobil uygulama geliştirme</a>,
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com/solutions/custom-applications"> ihtiyaca özel kurumsal yazılım</a>
              ve
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com/solutions/backup-storage"> KVKK uyumlu yedekleme ve S3 uyumlu depolama</a>
              hizmetleri sunar.
            </p>
            <p>
              <strong>Mobil uygulama geliştirme</strong> tarafında <strong>Flutter</strong> ile tek kod tabanından
              iOS ve Android için native performansta ürünler kuruyoruz; <strong>App Store yayın</strong>,
              <strong>Google Play Console</strong> yönetimi, push bildirimleri, offline çalışma, kripto imzalama
              ve sürüm yönetimini sözleşmeye dahil ediyoruz. Aynı ekip, web ve mobil tarafı tek bir
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com/product"> ürün omurgası</a>
              üzerinden teslim eder.
            </p>
            <p>
              Bölgesel olarak
              <strong> Alanya yazılım</strong>,
              <strong> Antalya yazılım</strong> ve
              <strong> İstanbul yazılım</strong>
              projeleri ağırlıklı olsa da, tüm Türkiye'de ve yurt dışında uzaktan teslim modeliyle çalışıyoruz.
              Kurumsal bir ihtiyacınız için kapsam çalışmasına başlamak isterseniz
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com/contact"> iletişim sayfası</a>
              üzerinden ulaşabilir ya da
              <a class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent" href="https://donedynamics.com/product/nextcloud"> Nextcloud Kurumsal Dijital Çalışma Alanı</a>
              ürünümüzü inceleyebilirsiniz.
            </p>
          </div>
        )}
      </div>
    </section>

    <footer class="border-t border-ink-200 bg-ink-50">
      <div class="container-page py-10 text-sm text-ink-600">
        <p>
          {lang === 'en' ? 'Operated by ' : 'Yayıncı: '}
          <a class="text-accent hover:underline" href={mainUrl}>Done Dynamics</a>
          {lang === 'en' ? ' · Alanya TEKMER, Türkiye.' : ' · Alanya TEKMER, Türkiye.'}
        </p>
        <p class="mt-2 text-ink-400">© {new Date().getFullYear()} Done Dynamics.</p>
      </div>
    </footer>
  </body>
</html>
