---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---
<Layout
  title="Done Dynamics Engineering — mühendislik notları"
  description="Kurumsal yazılım şirketi Done Dynamics ekibinden mühendislik yazıları: mimari kararlar, kod örnekleri, benchmark notları."
  lang="tr"
>
  <section class="mb-12">
    <p class="text-xs font-semibold uppercase tracking-wider text-ink-400">Done Dynamics · Engineering</p>
    <h1 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight text-ink-900">
      Mühendislik notları, mimari kararlar ve sahadan benchmark'lar.
    </h1>
    <p class="mt-4 text-base text-ink-600">
      Bu GitHub Pages sitesi, <a class="text-accent underline" href="https://donedynamics.com">donedynamics.com</a>
      ekibinin teknik karar süreçlerini, kod örneklerini ve gerçek üretim ortamından çıkan ölçümleri paylaştığı
      bir mühendislik blog'udur. Her yazı; problem → mimari → kod → benchmark → diagram → sonuç → referans
      yapısında ilerler.
    </p>
  </section>

  <section>
    <h2 class="text-lg font-semibold text-ink-900">Yazılar</h2>
    <ul class="mt-6 divide-y divide-ink-200 border-y border-ink-200">
      {posts.map((p) => (
        <li class="py-5">
          <a href={`/posts/${p.slug}/`} class="group block">
            <div class="flex flex-wrap items-center gap-2 text-xs text-ink-400">
              <span>{new Date(p.data.date).toLocaleDateString('tr-TR', { year: 'numeric', month: 'short', day: '2-digit' })}</span>
              {p.data.tags.map((t) => <span class="rounded-full border border-ink-200 px-2 py-0.5">#{t}</span>)}
            </div>
            <h3 class="mt-1 text-lg font-semibold text-ink-900 group-hover:text-accent">{p.data.title}</h3>
            <p class="mt-1 text-sm text-ink-600">{p.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
